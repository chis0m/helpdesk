PORT=8080
FRONTEND_URL=http://localhost:3000
GO_ENV=development
LOG_LEVEL=info
DB_HOST=localhost
DB_DATABASE=helpdesk
DB_USERNAME=admin
DB_PASSWORD=password
DB_PORT=3306
SEED_ADMIN_EMAIL=super.admin@secweb.ie
SEED_ADMIN_PASSWORD=password
SEED_ADMIN_FIRST_NAME=super
SEED_ADMIN_MIDDLE_NAME=
SEED_ADMIN_LAST_NAME=admin
# true | false — CA assessment users, staff, and tickets (seed/seeds/ca)
SEED_CA=true
APP_NAME=SecWeb HelpDesk
PASETO_SYMMETRIC_KEY=12345678901234567890123456789012
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h
CSRF_TOKEN_DURATION=60m
INVITE_TTL=72h
PASSWORD_RESET_TTL=1h
# log = URLs in app logs only | smtp = send via MAIL_* (STARTTLS when the server offers it)
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=SecWeb HelpDesk

# --- Mailtrap Email Testing (SMTP sandbox) ---
# In Mailtrap: Email Testing → Inboxes → your inbox → SMTP settings → copy credentials.
# Map curl --url 'smtp://sandbox.smtp.mailtrap.io:2525' --user 'USER:PASS' to:
#   MAIL_MAILER=smtp
#   MAIL_HOST=sandbox.smtp.mailtrap.io
#   MAIL_PORT=2525
#   MAIL_USERNAME=<SMTP user from Mailtrap>
#   MAIL_PASSWORD=<SMTP password from Mailtrap>
#   MAIL_FROM_ADDRESS=from@example.com
#   MAIL_FROM_NAME=SecWeb HelpDesk
